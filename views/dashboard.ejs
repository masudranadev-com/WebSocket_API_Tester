<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { meta, structuredData: null }) %>
  <body
    class="min-h-screen bg-base text-ink"
    data-username="<%= username %>"
    data-workspace-url="<%= workspaceUrl %>"
    data-csrf-token="<%= csrfToken %>"
  >
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute left-[-5rem] top-[-3rem] h-80 w-80 rounded-full bg-accent/18 blur-3xl"></div>
      <div class="absolute right-[-6rem] top-24 h-[26rem] w-[26rem] rounded-full bg-amber-300/20 blur-3xl"></div>
      <div class="absolute bottom-[-8rem] left-1/3 h-[24rem] w-[24rem] rounded-full bg-emerald-200/30 blur-3xl"></div>
      <div class="dashboard-grid absolute inset-0 opacity-60"></div>
    </div>

    <main class="relative mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
      <header class="surface-panel sticky top-3 z-30 overflow-visible px-4 py-5 sm:px-6">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(47,122,96,0.22),transparent_38%),radial-gradient(circle_at_top_right,rgba(253,186,116,0.24),transparent_32%)]"></div>

        <div class="relative flex gap-5 flex-row items-start justify-between">
          <div class="flex items-start gap-4">
            <div class="brand-badge">
              <span class="text-lg font-bold text-white">SD</span>
            </div>
          </div>

          <div id="header-menu-shell" class="relative self-start xl:self-center">
            <button
              id="header-menu-toggle"
              type="button"
              class="header-menu-button"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="header-menu-panel"
            >
              <span class="header-menu-glyph">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 7h16"></path>
                  <path d="M7 12h13"></path>
                  <path d="M10 17h10"></path>
                </svg>
              </span>

              <span class="min-w-0 text-left">
                <span class="block text-[11px] uppercase tracking-[0.28em] text-ink/42"><%= username %></span>
                <span class="mt-1 block text-sm font-semibold text-ink">Menu</span>
              </span>

              <span class="header-menu-caret">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m6 9 6 6 6-6"></path>
                </svg>
              </span>
            </button>

            <div id="header-menu-panel" class="header-menu-panel hidden">
              <button id="copy-workspace-base" type="button" class="header-menu-item">
                <span class="header-menu-item-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                  </svg>
                </span>
                <span>
                  <span class="block text-sm font-semibold text-ink">Copy base URL</span>
                  <span class="mt-1 block text-xs leading-5 text-ink/55">Grab the workspace base address instantly.</span>
                </span>
              </button>

              <button id="toggle-guide" type="button" class="header-menu-item">
                <span class="header-menu-item-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 6v12"></path>
                    <path d="M6 12h12"></path>
                    <circle cx="12" cy="12" r="9"></circle>
                  </svg>
                </span>
                <span>
                  <span class="block text-sm font-semibold text-ink">Pattern guide</span>
                  <span class="mt-1 block text-xs leading-5 text-ink/55">Open the placeholder examples and previews.</span>
                </span>
              </button>

              <button id="logout-button" type="button" class="header-menu-item header-menu-item-danger">
                <span class="header-menu-item-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <path d="m16 17 5-5-5-5"></path>
                    <path d="M21 12H9"></path>
                  </svg>
                </span>
                <span>
                  <span class="block text-sm font-semibold">Log out</span>
                  <span class="mt-1 block text-xs leading-5 text-current/75">Leave the workspace safely.</span>
                </span>
              </button>
            </div>
          </div>
        </div>
      </header>

      <section class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-5">
        <article class="metric-card">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">API routes</p>
          <p id="stat-api-count" class="mt-4 text-4xl font-bold">0</p>
        </article>

        <article class="metric-card">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">WS events</p>
          <p id="stat-ws-count" class="mt-4 text-4xl font-bold">0</p>
        </article>

        <article class="metric-card">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">REST hits</p>
          <p id="stat-api-hits" class="mt-4 text-4xl font-bold">0</p>
        </article>

        <article class="metric-card">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">WS triggers</p>
          <p id="stat-ws-triggers" class="mt-4 text-4xl font-bold">0</p>
        </article>

        <article class="metric-card">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Blocked IPs</p>
          <p id="stat-blocked-ips" class="mt-4 text-4xl font-bold">0</p>
          <p id="stat-blocked-at" class="mt-3 text-sm text-ink/55">No active blocks</p>
        </article>
      </section>

      <section class="surface-panel mt-6 p-4 sm:p-5 lg:p-6">
        <div class="flex gap-4 flex-row items-center justify-between">
          <div class="inline-flex rounded-[1.35rem] border border-ink/10 bg-white/80 p-1 shadow-sm">
            <button id="tab-apis" type="button" class="segment-button active">APIs</button>
            <button id="tab-ws" type="button" class="segment-button">WebSocket</button>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <label class="relative block w-full sm:w-80">
              <span class="sr-only">Search records</span>
              <input
                id="record-search"
                type="search"
                placeholder="Search endpoint, method, namespace, or event"
                class="input-shell w-full pr-12"
              />
            </label>

            <button id="create-record" type="button" class="primary-button whitespace-nowrap">
              Create API
            </button>
          </div>
        </div>

        <div id="feedback" class="mt-4 hidden rounded-[1.35rem] border px-4 py-3 text-sm"></div>

        <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p id="records-eyebrow" class="text-xs uppercase tracking-[0.24em] text-ink/45">APIs</p>
            <h2 id="records-title" class="mt-2 text-2xl font-semibold">All mock API endpoints</h2>
          </div>
          <p id="records-summary" class="text-sm text-ink/55"></p>
        </div>

        <div id="records-grid" class="mt-5 grid gap-4 xl:grid-cols-2"></div>
      </section>
    </main>

    <div id="entity-modal" class="fixed inset-0 z-40 hidden">
      <div id="entity-modal-backdrop" class="absolute inset-0 bg-ink/55 backdrop-blur-sm"></div>

      <div class="relative flex min-h-full items-end justify-center p-3 sm:items-center sm:p-6">
        <section
          id="entity-modal-panel"
          class="max-h-[94vh] w-full max-w-6xl overflow-hidden rounded-[2rem] border border-white/45 bg-panel shadow-shell"
        ></section>
      </div>
    </div>

    <div id="guide-modal" class="fixed inset-0 z-50 hidden">
      <div id="guide-backdrop" class="absolute inset-0 bg-ink/55 backdrop-blur-sm"></div>

      <div class="relative flex min-h-full items-end justify-center p-3 sm:items-center sm:p-6">
        <section class="max-h-[92vh] w-full max-w-5xl overflow-hidden rounded-[2rem] border border-white/45 bg-panel shadow-shell">
          <div class="grid gap-0 lg:grid-cols-[320px_minmax(0,1fr)]">
            <aside class="border-b border-ink/10 bg-[#edf5ef] p-6 lg:border-b-0 lg:border-r">
              <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Template guide</p>
              <h2 class="mt-3 text-3xl font-semibold leading-tight">Dynamic response patterns</h2>
              <p class="mt-4 text-sm leading-7 text-ink/68">
                Use these placeholders in API response examples and WebSocket payloads. SignalDock renders them live when the route is hit or the event is triggered.
              </p>

              <div class="mt-6 rounded-[1.5rem] border border-ink/10 bg-white/85 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-ink/45">Popular patterns</p>
                <div class="mt-3 space-y-3 font-mono text-sm text-ink/78">
                  <p>[[USERNAME]]</p>
                  <p>[[UUID]]</p>
                  <p>[[NUMBER_100000_999999]]</p>
                </div>
              </div>
            </aside>

            <div class="flex max-h-[92vh] flex-col">
              <div class="flex items-start justify-between gap-4 border-b border-ink/10 px-6 py-5">
                <div>
                  <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Available placeholders</p>
                  <p class="mt-2 text-sm text-ink/65">Close this panel when you are done.</p>
                </div>

                <button id="close-guide" type="button" class="secondary-button">
                  Close
                </button>
              </div>

              <div class="overflow-y-auto px-6 py-6">
                <div id="guide-list" class="grid gap-4 md:grid-cols-2"></div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <script src="/app.js" defer></script>
  </body>
</html>
