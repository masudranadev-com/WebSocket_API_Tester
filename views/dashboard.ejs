<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { meta, structuredData: null }) %>
  <body
    class="min-h-screen bg-base text-ink"
    data-username="<%= username %>"
    data-workspace-url="<%= workspaceUrl %>"
    data-csrf-token="<%= csrfToken %>"
  >
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute left-0 top-12 h-72 w-72 rounded-full bg-accent/12 blur-3xl"></div>
      <div class="absolute right-[-4rem] top-28 h-96 w-96 rounded-full bg-orange-200/30 blur-3xl"></div>
      <div class="dashboard-grid absolute inset-0 opacity-50"></div>
    </div>

    <main class="relative mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
      <header class="sticky top-4 z-20 rounded-[2rem] border border-ink/10 bg-panel/85 px-5 py-4 shadow-shell backdrop-blur">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-ink text-lg font-bold text-white">SD</div>
            <div>
              <p class="font-mono text-xs uppercase tracking-[0.28em] text-ink/45">SignalDock</p>
              <h1 class="text-2xl font-semibold">Workspace <span class="text-accent"><%= username %></span></h1>
            </div>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <div class="rounded-2xl border border-ink/10 bg-white/80 px-4 py-3">
              <p class="text-xs uppercase tracking-[0.25em] text-ink/45">Public base URL</p>
              <div class="mt-1 flex items-center gap-3">
                <span id="workspace-url" class="font-mono text-sm"><%= workspaceUrl %></span>
                <button
                  id="copy-workspace-url"
                  type="button"
                  class="rounded-xl bg-accentSoft px-3 py-2 text-xs font-semibold text-accent transition hover:bg-accent hover:text-white"
                >
                  Copy
                </button>
              </div>
            </div>

            <button
              id="logout-button"
              type="button"
              class="inline-flex items-center justify-center rounded-2xl border border-ink/10 bg-white/80 px-4 py-3 text-sm font-semibold transition hover:bg-white"
            >
              Log out
            </button>
          </div>
        </div>
      </header>

      <section class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
        <div class="rounded-[1.75rem] border border-ink/10 bg-panel/90 p-5 shadow-shell">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">API routes</p>
          <p id="stat-api-count" class="mt-4 text-4xl font-bold">0</p>
        </div>
        <div class="rounded-[1.75rem] border border-ink/10 bg-panel/90 p-5 shadow-shell">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">WS events</p>
          <p id="stat-ws-count" class="mt-4 text-4xl font-bold">0</p>
        </div>
        <div class="rounded-[1.75rem] border border-ink/10 bg-panel/90 p-5 shadow-shell">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">REST hits</p>
          <p id="stat-api-hits" class="mt-4 text-4xl font-bold">0</p>
        </div>
        <div class="rounded-[1.75rem] border border-ink/10 bg-panel/90 p-5 shadow-shell">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">WS triggers</p>
          <p id="stat-ws-triggers" class="mt-4 text-4xl font-bold">0</p>
        </div>
        <div class="rounded-[1.75rem] border border-ink/10 bg-panel/90 p-5 shadow-shell">
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Blocked IPs</p>
          <p id="stat-blocked-ips" class="mt-4 text-4xl font-bold">0</p>
          <p id="stat-blocked-at" class="mt-3 text-sm text-ink/55">No active blocks</p>
        </div>
      </section>

      <section class="mt-6 rounded-[2rem] border border-ink/10 bg-panel/85 p-4 shadow-shell backdrop-blur lg:p-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="inline-flex rounded-2xl border border-ink/10 bg-[#f5f1e8] p-1">
            <button id="tab-apis" type="button" class="dashboard-tab active rounded-xl px-4 py-2 text-sm font-semibold">APIs</button>
            <button id="tab-ws" type="button" class="dashboard-tab rounded-xl px-4 py-2 text-sm font-semibold">WebSocket</button>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row">
            <label class="relative block">
              <span class="sr-only">Search</span>
              <input
                id="list-search"
                type="search"
                placeholder="Search path, method, namespace, or event"
                class="w-full rounded-2xl border border-ink/10 bg-white/90 px-4 py-3 pr-11 text-sm outline-none transition focus:border-accent focus:ring-4 focus:ring-accent/10 sm:w-80"
              />
            </label>
            <button
              id="toggle-guide"
              type="button"
              class="inline-flex items-center justify-center rounded-2xl border border-ink/10 bg-white/90 px-4 py-3 text-sm font-semibold transition hover:bg-white"
            >
              Placeholder guide
            </button>
          </div>
        </div>

        <div class="mt-5 grid gap-5 xl:grid-cols-[340px_minmax(0,1fr)]">
          <aside class="rounded-[1.75rem] border border-ink/10 bg-[#f7f4ec] p-4">
            <div class="flex items-center justify-between gap-3">
              <div>
                <p id="list-heading-eyebrow" class="text-xs uppercase tracking-[0.24em] text-ink/45">APIs</p>
                <h2 id="list-heading-title" class="mt-2 text-xl font-semibold">Routes</h2>
              </div>
              <button
                id="new-item"
                type="button"
                class="inline-flex items-center justify-center rounded-2xl bg-ink px-3 py-2 text-sm font-semibold text-white transition hover:bg-ink/90"
              >
                New
              </button>
            </div>

            <div id="list-container" class="mt-4 space-y-3"></div>
          </aside>

          <section class="space-y-5">
            <div id="feedback" class="hidden rounded-2xl border px-4 py-3 text-sm"></div>

            <section id="api-editor" class="space-y-5">
              <div class="rounded-[1.75rem] border border-ink/10 bg-white p-5">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-ink/45">REST route</p>
                    <h2 id="api-form-title" class="mt-2 text-2xl font-semibold">Create an API endpoint</h2>
                  </div>
                  <div class="rounded-2xl bg-accentSoft px-4 py-2 text-sm font-medium text-accent">100 req/min per IP</div>
                </div>

                <form id="api-form" class="mt-6 grid gap-4">
                  <div class="grid gap-4 md:grid-cols-[140px_minmax(0,1fr)]">
                    <label class="space-y-2">
                      <span class="text-sm font-medium text-ink/80">Method</span>
                      <select id="api-method" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10">
                        <option>GET</option>
                        <option>POST</option>
                        <option>PUT</option>
                        <option>PATCH</option>
                        <option>DELETE</option>
                        <option>OPTIONS</option>
                        <option>HEAD</option>
                      </select>
                    </label>
                    <label class="space-y-2">
                      <span class="text-sm font-medium text-ink/80">Path</span>
                      <input id="api-path" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 font-mono text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder="/orders/:orderId" />
                    </label>
                  </div>

                  <label class="space-y-2">
                    <span class="text-sm font-medium text-ink/80">Response body</span>
                    <textarea id="api-response-body" class="min-h-[220px] w-full rounded-[1.5rem] border border-ink/10 bg-[#f9f6ef] px-4 py-4 font-mono text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder='{"orderId":"[[UUID]]","customer":"[[NAME]]"}'></textarea>
                  </label>

                  <div class="grid gap-4 md:grid-cols-2">
                    <label class="space-y-2">
                      <span class="text-sm font-medium text-ink/80">Status code</span>
                      <input id="api-status-code" type="number" min="100" max="599" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" />
                    </label>
                    <label class="space-y-2">
                      <span class="text-sm font-medium text-ink/80">Content type</span>
                      <input id="api-content-type" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder="application/json" />
                    </label>
                  </div>

                  <label class="space-y-2">
                    <span class="text-sm font-medium text-ink/80">Notes</span>
                    <input id="api-notes" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder="Optional label or teammate note" />
                  </label>

                  <details class="rounded-[1.5rem] border border-ink/10 bg-[#f6f3eb] p-4">
                    <summary class="cursor-pointer text-sm font-semibold">Advanced settings</summary>
                    <div class="mt-4 grid gap-4">
                      <label class="space-y-2">
                        <span class="text-sm font-medium text-ink/80">Headers JSON</span>
                        <textarea id="api-headers-json" class="min-h-[140px] w-full rounded-[1.25rem] border border-ink/10 bg-white px-4 py-4 font-mono text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder='{"Cache-Control":"no-store"}'></textarea>
                      </label>
                      <div class="grid gap-4 md:grid-cols-2">
                        <label class="space-y-2">
                          <span class="text-sm font-medium text-ink/80">Delay (ms)</span>
                          <input id="api-delay-ms" type="number" min="0" max="30000" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" />
                        </label>
                        <label class="flex items-center gap-3 rounded-2xl border border-ink/10 bg-white px-4 py-3">
                          <input id="api-is-active" type="checkbox" class="h-5 w-5 rounded border-ink/20 text-accent focus:ring-accent" />
                          <span class="text-sm font-medium text-ink/80">Route is active</span>
                        </label>
                      </div>
                    </div>
                  </details>

                  <div class="flex flex-col gap-3 border-t border-ink/10 pt-4 sm:flex-row">
                    <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-ink px-4 py-3 text-sm font-semibold text-white transition hover:bg-ink/90">Save API</button>
                    <button id="delete-api" type="button" class="inline-flex items-center justify-center rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700 transition hover:bg-rose-100">Delete</button>
                  </div>
                </form>
              </div>

              <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_320px]">
                <div class="rounded-[1.75rem] border border-ink/10 bg-white p-5">
                  <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                      <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Test panel</p>
                      <h3 class="mt-2 text-xl font-semibold">Try the public endpoint</h3>
                    </div>
                    <button id="copy-api-url" type="button" class="rounded-2xl bg-accentSoft px-3 py-2 text-sm font-semibold text-accent transition hover:bg-accent hover:text-white">Copy URL</button>
                  </div>

                  <p id="api-public-url" class="mt-4 break-all rounded-2xl bg-[#f7f3ea] px-4 py-3 font-mono text-sm"></p>

                  <label class="mt-4 block space-y-2">
                    <span class="text-sm font-medium text-ink/80">Test request body</span>
                    <textarea id="api-test-body" class="min-h-[120px] w-full rounded-[1.25rem] border border-ink/10 bg-[#f9f6ef] px-4 py-4 font-mono text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder='{"demo":true}'></textarea>
                  </label>

                  <div class="mt-4 flex flex-col gap-3 sm:flex-row">
                    <button id="run-api-test" type="button" class="inline-flex items-center justify-center rounded-2xl bg-accent px-4 py-3 text-sm font-semibold text-white transition hover:bg-accent/90">Run test</button>
                    <button id="copy-api-curl" type="button" class="inline-flex items-center justify-center rounded-2xl border border-ink/10 bg-white px-4 py-3 text-sm font-semibold transition hover:bg-[#f8f6f0]">Copy curl</button>
                  </div>

                  <pre id="api-test-result" class="mt-4 min-h-[180px] overflow-auto rounded-[1.25rem] bg-ink px-4 py-4 font-mono text-sm text-white"></pre>
                </div>

                <aside class="space-y-5">
                  <div class="rounded-[1.75rem] border border-ink/10 bg-white p-5">
                    <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Route analytics</p>
                    <div class="mt-4 space-y-4">
                      <div>
                        <p class="text-sm text-ink/55">Total hits</p>
                        <p id="api-hit-count" class="mt-1 text-3xl font-bold">0</p>
                      </div>
                      <div>
                        <p class="text-sm text-ink/55">Last hit</p>
                        <p id="api-last-hit" class="mt-1 text-sm font-medium">No traffic yet</p>
                      </div>
                    </div>
                  </div>
                  <div class="rounded-[1.75rem] border border-ink/10 bg-white p-5">
                    <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Quick note</p>
                    <p class="mt-4 text-sm leading-6 text-ink/65">
                      Dynamic tokens are rendered when the request arrives, not when you save the route.
                    </p>
                  </div>
                </aside>
              </div>
            </section>

            <section id="ws-editor" class="hidden space-y-5">
              <div class="rounded-[1.75rem] border border-ink/10 bg-white p-5">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Realtime event</p>
                    <h2 id="ws-form-title" class="mt-2 text-2xl font-semibold">Create a WebSocket event</h2>
                  </div>
                  <div class="rounded-2xl bg-accentSoft px-4 py-2 text-sm font-medium text-accent">Socket.IO namespace</div>
                </div>

                <form id="ws-form" class="mt-6 grid gap-4">
                  <label class="space-y-2">
                    <span class="text-sm font-medium text-ink/80">Namespace</span>
                    <input id="ws-namespace" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 font-mono text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder="/orders" />
                  </label>

                  <label class="space-y-2">
                    <span class="text-sm font-medium text-ink/80">Event name</span>
                    <input id="ws-event-name" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 font-mono text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder="order.created" />
                  </label>

                  <label class="space-y-2">
                    <span class="text-sm font-medium text-ink/80">Payload template</span>
                    <textarea id="ws-payload-template" class="min-h-[220px] w-full rounded-[1.5rem] border border-ink/10 bg-[#f9f6ef] px-4 py-4 font-mono text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder='{"id":"[[UUID]]","customer":"[[NAME]]"}'></textarea>
                  </label>

                  <label class="space-y-2">
                    <span class="text-sm font-medium text-ink/80">Notes</span>
                    <input id="ws-notes" class="w-full rounded-2xl border border-ink/10 bg-white px-4 py-3 text-sm outline-none focus:border-accent focus:ring-4 focus:ring-accent/10" placeholder="Optional event purpose" />
                  </label>

                  <label class="flex items-center gap-3 rounded-2xl border border-ink/10 bg-[#f7f4ec] px-4 py-3">
                    <input id="ws-is-active" type="checkbox" class="h-5 w-5 rounded border-ink/20 text-accent focus:ring-accent" />
                    <span class="text-sm font-medium text-ink/80">Event is active</span>
                  </label>

                  <div class="flex flex-col gap-3 border-t border-ink/10 pt-4 sm:flex-row">
                    <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-ink px-4 py-3 text-sm font-semibold text-white transition hover:bg-ink/90">Save event</button>
                    <button id="delete-ws" type="button" class="inline-flex items-center justify-center rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700 transition hover:bg-rose-100">Delete</button>
                  </div>
                </form>
              </div>

              <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_320px]">
                <div class="rounded-[1.75rem] border border-ink/10 bg-white p-5">
                  <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                      <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Trigger panel</p>
                      <h3 class="mt-2 text-xl font-semibold">Broadcast payload</h3>
                    </div>
                    <button id="copy-ws-snippet" type="button" class="rounded-2xl bg-accentSoft px-3 py-2 text-sm font-semibold text-accent transition hover:bg-accent hover:text-white">Copy client snippet</button>
                  </div>

                  <p id="ws-namespace-preview" class="mt-4 break-all rounded-2xl bg-[#f7f3ea] px-4 py-3 font-mono text-sm"></p>

                  <div class="mt-4 flex flex-col gap-3 sm:flex-row">
                    <button id="trigger-ws" type="button" class="inline-flex items-center justify-center rounded-2xl bg-accent px-4 py-3 text-sm font-semibold text-white transition hover:bg-accent/90">Trigger event</button>
                    <button id="copy-ws-payload" type="button" class="inline-flex items-center justify-center rounded-2xl border border-ink/10 bg-white px-4 py-3 text-sm font-semibold transition hover:bg-[#f8f6f0]">Copy payload</button>
                  </div>

                  <pre id="ws-trigger-result" class="mt-4 min-h-[180px] overflow-auto rounded-[1.25rem] bg-ink px-4 py-4 font-mono text-sm text-white"></pre>
                </div>

                <aside class="space-y-5">
                  <div class="rounded-[1.75rem] border border-ink/10 bg-white p-5">
                    <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Event analytics</p>
                    <div class="mt-4 space-y-4">
                      <div>
                        <p class="text-sm text-ink/55">Total triggers</p>
                        <p id="ws-trigger-count" class="mt-1 text-3xl font-bold">0</p>
                      </div>
                      <div>
                        <p class="text-sm text-ink/55">Last trigger</p>
                        <p id="ws-last-trigger" class="mt-1 text-sm font-medium">No triggers yet</p>
                      </div>
                    </div>
                  </div>
                  <div class="rounded-[1.75rem] border border-ink/10 bg-white p-5">
                    <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Client connection</p>
                    <p class="mt-4 text-sm leading-6 text-ink/65">
                      Connect with Socket.IO to the namespace shown here, then listen for the event name you configured.
                    </p>
                  </div>
                </aside>
              </div>
            </section>
          </section>
        </div>
      </section>
    </main>

    <aside id="guide-drawer" class="fixed inset-y-0 right-0 z-30 hidden w-full max-w-md border-l border-ink/10 bg-panel/95 p-6 shadow-shell backdrop-blur">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.24em] text-ink/45">Reference</p>
          <h2 class="mt-2 text-2xl font-semibold">Placeholder guide</h2>
        </div>
        <button id="close-guide" type="button" class="rounded-2xl border border-ink/10 px-3 py-2 text-sm font-semibold">Close</button>
      </div>

      <div id="guide-list" class="mt-6 space-y-3"></div>
    </aside>

    <script src="/app.js" defer></script>
  </body>
</html>
